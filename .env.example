# LeLamp Environment Configuration

# ============================================
# MQTT Broker Configuration
# ============================================
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=lelamp
MQTT_PASSWORD=your_password_here
MQTT_USE_TLS=false

# ============================================
# LeLamp Configuration
# ============================================
LAMP_ID=lelamp
MQTT_MODE=hybrid  # Options: local, publish, hybrid, command

# ============================================
# Sensor Publishing Configuration
# ============================================
MQTT_PUBLISH_DISTANCE=true
MQTT_PUBLISH_RATE=10  # Hz - distance readings per second
MQTT_PUBLISH_WAVE_EVENTS=true

# ============================================
# Ultrasonic Sensor Configuration
# ============================================
ULTRASONIC_TRIGGER_PIN=23
ULTRASONIC_ECHO_PIN=24
ULTRASONIC_DETECTION_THRESHOLD=0.5  # meters (50cm)
ULTRASONIC_WAVE_SPEED_THRESHOLD=0.15  # m/s
ULTRASONIC_SAMPLE_RATE=10.0  # Hz

# ============================================
# LiveKit Configuration (Voice Agent)
# ============================================
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key
